{% extends "layout.twig" %}
{% block title %} Tienda - uoMusic {% endblock %}
{% block main_container %}
<!-- BÃºsqueda -->
 <div class="row">
 <div id="custom-search-input ">
 <form method="get" action="/shop">
 <div class="input-group col-xs-8 col-sm-6 col-md-4 col-lg-5 pull-right">
 <input id="search" type="text" class="search-query form-control"
 placeholder="Nombre de la canciÃ³n" name="search"/>
 <span class="input-group-btn">
<button class="btn" type="submit">
 <span class="glyphicon glyphicon-search"></span>
</button>
</span>
 </div>
 </form>
 </div>
 </div>
<h2>Canciones</h2>
 <div class="row">
 <!-- Inicio del Bloque canciÃ³n -->
 {% for song in songs %}
 <div class="col-xs-6 col-sm-6 col-md-4 col-lg-3">
 <div style="width:200px">
 <a href="/songs/{{song._id}}">
 <img src="/covers/{{song._id}}.png" alt="logo"/>
 <!-- http://www.socicon.com/generator.php -->
 <div>{{ song.title }} </div>
 <div class="small">{{ song.author }} </div>
 <div class="text-right">{{ song.price }} â‚¬</div>
 </a>
 <form method="post" action="/songs/favorites/add/{{song._id}}" class="text-right">
  <button type="submit" class="btn btn-xs btn-default">Favorito</button>
 </form>
 </div>
 </div>
 {% endfor %}
 <!-- Fin del Bloque canciÃ³n -->
 </div>
 <!-- PaginaciÃ³n mostrar la actual y 2 anteriores y dos siguientes -->
 <div class="row text-center">
 <ul class="pagination">
 {% for page in pages %}
 <li class="page-item" id="pi-{{ page }}"><a class="page-link" href="/shop?search={{ search }}&page={{ page }}">{{ page }}</a></li>
 {% endfor %}
 </ul>
 </div>
 <script>
   $("#pi-" + {{ currentPage }}).addClass("active");
 </script>
{% endblock %}
